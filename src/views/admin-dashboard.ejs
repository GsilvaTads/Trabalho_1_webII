<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>MarketMVP | Painel administrativo</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700&family=Plus+Jakarta+Sans:wght@400;600;700&display=swap" rel="stylesheet" />
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
      tailwind.config = {
        theme: {
          extend: {
            fontFamily: {
              display: ["Space Grotesk", "sans-serif"],
              body: ["Plus Jakarta Sans", "sans-serif"],
            },
            colors: {
              brand: { 50: "#F8F7F2", 100: "#EDE8D8", 200: "#D9CEAA", 300: "#C7B57D", 400: "#B99B56", 500: "#A8853A", 600: "#886B2F", 700: "#665024", 800: "#453519", 900: "#251E10" },
              accent: { 500: "#0A7D7A", 600: "#075F5D" },
              coral: { 500: "#E66A4E", 600: "#D55336" },
            },
          },
        },
      };
    </script>
  </head>
  <body class="bg-brand-50 font-body text-brand-900">
    <header class="border-b border-brand-200/80 bg-white/75 backdrop-blur sticky top-0 z-10">
      <div class="mx-auto flex max-w-7xl items-center justify-between px-4 py-4 sm:px-6 lg:px-8">
        <a href="/" class="font-display text-xl font-bold">MarketMVP</a>
        <nav class="flex gap-5 text-sm font-medium">
          <a href="/logout" class="font-bold text-coral-600 hover:text-coral-700">Sair</a>
        </nav>
      </div>
    </header>

    <main class="mx-auto max-w-7xl space-y-6 px-4 py-8 sm:px-6 lg:px-8">
      
      <div class="flex flex-wrap items-center justify-between gap-4">
        <div>
          <h1 class="font-display text-3xl font-bold">Painel administrativo</h1>
          <p class="text-sm text-brand-700">Gestão de utilizadores e auditoria (ISO 12207).</p>
        </div>
        <a href="/admin/logs" class="rounded-xl border border-brand-300 bg-white px-4 py-2.5 text-sm font-bold hover:bg-brand-100 transition-colors shadow-sm">
          Ver Logs de Auditoria
        </a>
      </div>

      <section class="rounded-3xl border border-brand-200 bg-white p-6 shadow-sm">
        <div class="grid gap-3 sm:grid-cols-3">
          <div class="rounded-2xl bg-brand-100 p-4">
            <p class="text-xs font-semibold uppercase tracking-wider text-brand-600">Contas totais</p>
            <p class="mt-2 font-display text-3xl font-bold"><%= usuarios.length %></p>
          </div>
          <div class="rounded-2xl bg-brand-100 p-4">
            <p class="text-xs font-semibold uppercase tracking-wider text-accent-600">Contas ativas</p>
            <p class="mt-2 font-display text-3xl font-bold">
              <%= usuarios.filter(u => u.status === 'ativo').length %>
            </p>
          </div>
          <div class="rounded-2xl bg-brand-100 p-4">
            <p class="text-xs font-semibold uppercase tracking-wider text-coral-600">Contas inativas</p>
            <p class="mt-2 font-display text-3xl font-bold">
              <%= usuarios.filter(u => u.status !== 'ativo').length %>
            </p>
          </div>
        </div>
      </section>

      <section class="rounded-3xl border border-brand-200 bg-white p-6 shadow-sm">
        <h2 class="font-display text-2xl font-bold mb-4">Lista de utilizadores</h2>
        <div class="overflow-x-auto rounded-2xl border border-brand-200">
          <table class="min-w-full text-left text-sm">
            <thead class="bg-brand-100 text-brand-800">
              <tr>
                <th class="px-4 py-3 font-semibold">Nome</th>
                <th class="px-4 py-3 font-semibold">Perfil</th>
                <th class="px-4 py-3 font-semibold">E-mail</th>
                <th class="px-4 py-3 font-semibold">Status</th>
                <th class="px-4 py-3 font-semibold text-right">Ações</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-brand-200 bg-white">
              <% if (usuarios && usuarios.length > 0) { %>
                <% usuarios.forEach(user => { %>
                  <tr class="hover:bg-brand-50/50 transition-colors">
                    <td class="px-4 py-3 font-semibold"><%= user.nome %></td>
                    <td class="px-4 py-3 capitalize"><%= user.perfil %></td>
                    <td class="px-4 py-3 text-brand-700"><%= user.email %></td>
                    <td class="px-4 py-3">
                      <span class="rounded-full px-2 py-1 text-xs font-semibold <%= user.status === 'ativo' ? 'bg-accent-500/10 text-accent-600' : 'bg-brand-200 text-brand-700' %>">
                        <%= user.status === 'ativo' ? 'Ativo' : 'Inativo' %>
                      </span>
                    </td>
                    <td class="px-4 py-3 text-right">
                      <form action="/auth/toggle-status" method="POST">
                        <input type="hidden" name="userId" value="<%= user.id %>">
                        <input type="hidden" name="currentStatus" value="<%= user.status %>">
                        <button type="submit" class="rounded-lg px-3 py-1.5 text-xs font-bold transition-all active:scale-95 <%= user.status === 'ativo' ? 'bg-coral-500 text-white hover:bg-coral-600' : 'border border-brand-300 text-brand-700 hover:bg-brand-100' %>">
                          <%= user.status === 'ativo' ? 'DESATIVAR' : 'REATIVAR' %>
                        </button>
                      </form>
                    </td>
                  </tr>
                <% }) %>
              <% } else { %>
                <tr>
                  <td colspan="5" class="px-4 py-8 text-center text-brand-600 italic">Nenhum utilizador encontrado.</td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </section>
    </main>
  </body>
</html>