<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>MarketMVP | Logs de Auditoria</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700&family=Plus+Jakarta+Sans:wght@400;600;700&display=swap" rel="stylesheet" />
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
      tailwind.config = {
        theme: {
          extend: {
            fontFamily: { display: ["Space Grotesk", "sans-serif"], body: ["Plus Jakarta Sans", "sans-serif"] },
            colors: {
              brand: { 50: "#F8F7F2", 100: "#EDE8D8", 200: "#D9CEAA", 300: "#C7B57D", 400: "#B99B56", 500: "#A8853A", 600: "#886B2F", 700: "#665024", 800: "#453519", 900: "#251E10" },
              accent: { 500: "#0A7D7A", 600: "#075F5D" },
              coral: { 500: "#E66A4E" }
            }
          }
        }
      };
    </script>
  </head>
  <body class="bg-brand-50 font-body text-brand-900">
    <header class="border-b border-brand-200/80 bg-white/75 backdrop-blur sticky top-0 z-10">
      <div class="mx-auto flex max-w-7xl items-center justify-between px-4 py-4 sm:px-6 lg:px-8">
        <a href="/" class="font-display text-xl font-bold">MarketMVP</a>
        <nav class="flex gap-5 text-sm font-medium">
          <a href="/admin-dashboard" class="hover:text-accent-600">Painel de Usuários</a>
          <a href="/logout" class="font-bold text-coral-600">Sair</a>
        </nav>
      </div>
    </header>

    <main class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
      <section class="rounded-3xl border border-brand-200 bg-white p-6 shadow-sm">
        <div class="mb-6">
          <h1 class="font-display text-3xl font-bold">Logs de Auditoria</h1>
          <p class="text-sm text-brand-700 mt-1">Histórico completo de ações realizadas na plataforma (ISO 12207).</p>
        </div>

        <div class="overflow-x-auto rounded-2xl border border-brand-200">
          <table class="min-w-full text-left text-sm">
            <thead class="bg-brand-100 text-brand-800">
              <tr>
                <th class="px-4 py-3 font-semibold">Data/Hora</th>
                <th class="px-4 py-3 font-semibold">Usuário ID</th>
                <th class="px-4 py-3 font-semibold">Método</th>
                <th class="px-4 py-3 font-semibold">Rota</th>
                <th class="px-4 py-3 font-semibold">Ação</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-brand-200 bg-white">
              <% if (logs && logs.length > 0) { %>
                <% logs.forEach(log => { %>
                  <tr class="hover:bg-brand-50/50 transition-colors">
                    <td class="px-4 py-3 text-brand-600 font-mono text-xs"><%= log.data_hora %></td>
                    <td class="px-4 py-3 font-bold"><%= log.usuario_id || 'Visitante' %></td>
                    <td class="px-4 py-3">
                      <span class="px-2 py-0.5 rounded text-[10px] font-bold uppercase <%= log.metodo === 'POST' ? 'bg-accent-500 text-white' : 'bg-brand-200' %>">
                        <%= log.metodo %>
                      </span>
                    </td>
                    <td class="px-4 py-3 text-brand-700"><%= log.rota %></td>
                    <td class="px-4 py-3 italic text-brand-800"><%= log.acao %></td>
                  </tr>
                <% }) %>
              <% } else { %>
                <tr>
                  <td colspan="5" class="px-4 py-8 text-center text-brand-500 italic">Nenhum log registrado ainda.</td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </section>
    </main>
  </body>
</html>