<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>MarketMVP | Ativação de Conta</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
      tailwind.config = {
        theme: {
          extend: {
            colors: {
              brand: { 50: "#F8F7F2", 100: "#EDE8D8", 200: "#D9CEAA", 500: "#A8853A", 900: "#251E10" },
              accent: { 500: "#0A7D7A", 600: "#075F5D" },
            },
          },
        },
      };
    </script>
  </head>
  <body class="bg-brand-50 text-brand-900 font-sans min-h-screen flex items-center justify-center p-4">
    <div class="max-w-md w-full bg-white rounded-3xl border border-brand-200 shadow-xl p-8">
      <div class="text-center mb-8">
        <h1 class="text-3xl font-bold mb-2">Verifique sua conta</h1>
        <p class="text-brand-700 text-sm">Insira o código de 6 dígitos enviado para o seu e-mail para ativar seu acesso.</p>
      </div>

      <% if (locals.error) { %>
        <div class="mb-6 p-4 bg-red-50 border border-red-200 text-red-600 rounded-xl text-sm font-medium">
          <%= error %>
        </div>
      <% } %>

      <form action="/auth/verify" method="POST" class="space-y-5">
        <div>
          <label class="block text-xs font-bold uppercase tracking-wider text-brand-600 mb-2">E-mail cadastrado</label>
          <input type="email" name="email" required 
                 class="w-full px-4 py-3 rounded-xl border border-brand-200 focus:ring-2 focus:ring-accent-500 focus:outline-none transition-all"
                 placeholder="exemplo@email.com">
        </div>

        <div>
          <label class="block text-xs font-bold uppercase tracking-wider text-brand-600 mb-2">Código de Ativação</label>
          <input type="text" name="codigo" required maxlength="6"
                 class="w-full px-4 py-3 rounded-xl border border-brand-200 focus:ring-2 focus:ring-accent-500 focus:outline-none transition-all text-center text-2xl tracking-[0.5em] font-bold"
                 placeholder="000000">
        </div>

        <button type="submit" 
                class="w-full bg-accent-500 hover:bg-accent-600 text-white font-bold py-4 rounded-xl shadow-lg shadow-accent-500/20 transition-all active:scale-[0.98]">
          Ativar Minha Conta
        </button>
      </form>

      <div class="mt-8 text-center border-t border-brand-100 pt-6">
        <p class="text-sm text-brand-700">
          Não recebeu o código? <a href="/signup" class="text-accent-600 font-bold hover:underline">Tente cadastrar novamente</a>
        </p>
      </div>
    </div>
  </body>
</html>