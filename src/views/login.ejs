<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>MarketMVP | Entrar</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700&family=Plus Jakarta Sans:wght@400;600;700&display=swap" rel="stylesheet" />
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
      tailwind.config = {
        theme: {
          extend: {
            fontFamily: {
              display: ["Space Grotesk", "sans-serif"],
              body: ["Plus Jakarta Sans", "sans-serif"],
            },
            colors: {
              brand: { 50: "#F8F7F2", 100: "#EDE8D8", 200: "#D9CEAA", 300: "#C7B57D", 400: "#B99B56", 500: "#A8853A", 600: "#886B2F", 700: "#665024", 800: "#453519", 900: "#251E10" },
              accent: { 500: "#0A7D7A", 600: "#075F5D" },
              coral: { 500: "#E66A4E", 600: "#D55336" },
            },
          },
        },
      };
    </script>
  </head>
  <body class="bg-brand-50 font-body text-brand-900">
    <div class="flex min-h-screen items-center justify-center p-4">
      <div class="w-full max-w-md rounded-3xl border border-brand-200 bg-white p-8 shadow-sm">
        <header class="text-center">
          <h1 class="font-display text-3xl font-bold">MarketMVP</h1>
          <p class="mt-2 text-sm text-brand-700">Acesse sua conta para continuar.</p>
        </header>

        <% if (locals.error) { %>
            <div class="mt-4 p-3 bg-coral-500/10 border border-coral-500/20 text-coral-600 rounded-xl text-sm font-semibold text-center">
                <%= error %>
            </div>
        <% } %>

        <form action="/auth/login" method="POST" class="mt-8 space-y-4">
          <label class="block">
            <span class="mb-1 block text-sm font-medium">Email</span>
            <input type="email" name="email" required placeholder="you@example.com" class="w-full rounded-xl border border-brand-300 px-4 py-2.5 outline-none ring-coral-500 focus:ring" />
          </label>
          <label class="block">
            <span class="mb-1 block text-sm font-medium">Senha</span>
            <input type="password" name="password" required placeholder="********" class="w-full rounded-xl border border-brand-300 px-4 py-2.5 outline-none ring-coral-500 focus:ring" />
          </label>
          
          <button type="submit" class="w-full rounded-xl bg-brand-900 px-4 py-3 font-semibold text-brand-50 hover:bg-brand-800 transition-colors">
            Entrar
          </button>
        </form>

        <p class="mt-8 text-center text-sm text-brand-700">
          Não tem uma conta? <a href="/signup" class="font-bold text-brand-900 hover:underline">Criar conta</a>
        </p>
      </div>
    </div>
  </body>
</html>